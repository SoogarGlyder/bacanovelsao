{
  "version": 2,
  "builds": [
    {
      "src": "package.json", 
      "use": "@vercel/static-build",
      "config": {
        "runtime": "nodejs18.x",
        "outputDirectory": "dist", 
        "buildCommand": "npm run build"
      }
    },
    {
      "src": "api/index.js", 
      "use": "@vercel/node",
      "config": {
        "runtime": "nodejs18.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)", 
      "dest": "api/index.js"
    },
    {
      "src": "/[^/.]+",
      "dest": "dist/index.html"
    },
    {
      "src": "/chapter/[^/.]+",
      "dest": "dist/index.html"
    },
    {
      "src": "/(.*)", 
      "dest": "dist/index.html" 
    }
  ]
}