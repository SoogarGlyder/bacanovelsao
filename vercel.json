{
  "functions": {
    "api/index.js": {
      "runtime": "nodejs@20.x" 
    }
  },

  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/" 
    }
  ]
}